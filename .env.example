# Copy this file to ".env" and fill in your free KRX account credentials.
# data.krx.co.kr now requires a logged-in account for its data endpoints.
# The .env file is gitignored and never committed.

KRX_ID=your_krx_login_id_here
KRX_PW=your_krx_password_here

